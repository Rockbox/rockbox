        "patchSetId": 4
      },
      "lineNbr": 71,
      "author": {
        "id": 1000718
      },
      "writtenOn": "2021-03-03T22:54:08Z",
      "side": 1,
      "message": "Currently the audio is running off SCLK_A \u003d APLL \u003d 1008 MHz, and MPLL is disabled. I found it was possible to handle all the required sampling frequencies without having to use the second PLL.\n\nIt\u0027s possible to dial down APLL, but this would have to be done globally at startup and we\u0027d lose the ability to run the CPU at 1 GHz.",
      "parentUuid": "2c9a0931_fe9443ba",
      "range": {
        "startLine": 71,
        "startChar": 0,
        "endLine": 71,
        "endChar": 1
      },
