      "writtenOn": "2021-03-03T21:32:53Z",
      "side": 1,
      "message": "We can use the WSBH instruction to implement native byteswapping routines.  (mips32r2+ only!)",
      "range": {
        "startLine": 40,
        "startChar": 7,
        "endLine": 40,
