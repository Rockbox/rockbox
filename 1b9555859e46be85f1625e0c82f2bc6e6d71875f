        "id": 1000603
      },
      "writtenOn": "2021-03-03T21:32:53Z",
      "side": 1,
      "message": "it would be good to optimize this a bit, so we don\u0027t run the PLL any faster than we need.  but this is down-the-line..",
      "range": {
        "startLine": 71,
        "startChar": 0,
        "endLine": 71,
        "endChar": 1
      },
      "revId": "1b9555859e46be85f1625e0c82f2bc6e6d71875f",
