      "message": "Create a function:\n/* Remove any device from the global list if they meet the deletion criteria: no references and disconnected.\n * NOTE: will lock the global list */\nvoid hwstub_cleanup_devices()\n{\n  pthread_mutex_lock(\u0026devlist_mutex);\n  for(int i \u003d 0; i \u003c (int)g_devlist.size(); i++)\n  {\n     if(!g_devlist[i]-\u003econnected() \u0026\u0026 !g_devlist[i]-\u003eis_referenced())\n     {\n        delete g_devlist[i].\n        g_devlist.erase(g_devlist.begin() + i);\n        i--;\n     }\n  }\n  pthread_mutex_unlock(\u0026devlist_mutex);\n}",
