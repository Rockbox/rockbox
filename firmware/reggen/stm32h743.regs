        -- 14 AOE
        -- 13 BKP
        -- 12 BKE
        -- 11 OSSR
        -- 10 OSSI
        09 08 LOCK
        07 00 DTG
    }

    DCR @ 0x48 : reg {
        12 08 DBL
        04 00 DBA
    }

    DMAR @ 0x4c : reg

    CCMR3_OUT @ 0x54 : reg {
        -- 24 OC6M3
        -- 16 OC5M3
        -- 15 OC6CE
        14 12 OC6M
        -- 11 OC6PE
        -- 10 OC6FE
        -- 07 OC5CE
        06 04 OC5M
        -- 03 OC5PE
        -- 02 OC5FE
    }

    CCR5 @ 0x58 : reg {
        -- 31 GC5C3
        -- 30 GC5C2
        -- 29 GC5C1
        15 00 CCR5
    }

    CCR6 @ 0x5c : reg

    AF1 @ 0x60 : reg {
        17 14 ETRSEL
        -- 11 BKCMP2P
        -- 10 BKCMP1P
        -- 09 BKINP
        -- 08 BKDFxBKxE // differs for TIM1/TIM8
        -- 02 BKCMP2E
        -- 01 BKCMP1E
        -- 00 BKINE
    }

    AF2 @ 0x64 : reg {
        -- 11 BK2CMP2P
        -- 10 BK2CMP1P
        -- 09 BK2INP
        -- 08 BK2DFxBKxE // differs for TIM1/TIM8
        -- 02 BK2CMP2E
        -- 01 BK2CMP1E
        -- 00 BK2INE
    }

    TISEL @ 0x68 : reg {
        27 24 TI4SEL
        19 16 TI3SEL
        11 08 TI2SEL
        03 00 TI1SEL
    }
}

