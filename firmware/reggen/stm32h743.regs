        14 12 SMP14 : SMPTIME
        11 09 SMP13 : SMPTIME
        08 06 SMP12 : SMPTIME
        05 03 SMP11 : SMPTIME
        02 00 SMP10 : SMPTIME
    }

    PCSEL @ 0x1c : reg
    LTR1 @ 0x20 : reg
    HTR1 @ 0x24 : reg

    SQR1 @ 0x30 : reg {
