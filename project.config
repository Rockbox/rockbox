[project]
	description = The Rockbox source code.
[submit]
	action = cherry pick
[access "refs/*"]
	owner = group Administrators
	create = group Override Permissions
	forgeAuthor = group Override Permissions
	forgeCommitter = group Override Permissions
	push = +force group Override Permissions
	pushTag = +force group Override Permissions
	pushMerge = group Override Permissions
